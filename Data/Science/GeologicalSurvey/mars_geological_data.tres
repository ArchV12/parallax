[ext_resource type="Script" path="res://scripts/science/GeologicalSurveyData.gd" id="1"]

[resource]
script = ExtResource("1")
body_id = "Mars"
composition = Array[String](["Basalt", "Iron Oxide Regolith", "Sedimentary Deposits"])
